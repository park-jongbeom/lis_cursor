# ─── FastAPI ──────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=your-jwt-secret-key-here
ALLOWED_ORIGINS=["http://localhost:3000"]

# ─── Database ─────────────────────────────────────────────────────────────────
# 로컬(dev): localhost / 운영(prod): Docker 서비스명 (예: idr-postgres)
DATABASE_URL=postgresql+asyncpg://idr:password@localhost:15432/idr_analytics

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Analysis Routing ─────────────────────────────────────────────────────────
AI_ESCALATION_THRESHOLD=70
PANDAS_MAX_ROWS=2000000

# ─── LLM (Claude API) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=4096

# ─── Ollama (온프레미스 옵션) ─────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─── Dify (Self-hosted) ───────────────────────────────────────────────────────
DIFY_API_BASE_URL=http://localhost/v1
DIFY_API_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DIFY_WORKFLOW_ID=your-workflow-id-here

# ─── SCM / CRM ───────────────────────────────────────────────────────────────
PROPHET_CHANGEPOINT_SCALE=0.05
FORECAST_DEFAULT_DAYS=30
KMEANS_DEFAULT_CLUSTERS=4
CHURN_RECENCY_THRESHOLD_DAYS=90
