# ─── FastAPI ──────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=your-jwt-secret-key-here
# CORS 허용 출처 — 반드시 JSON 배열 형태의 문자열이어야 함(예: 아래 한 줄). 잘못된 형식이면 앱·pytest 기동 시 SettingsError.
# 쉘에 export된 ALLOWED_ORIGINS가 있으면 .env보다 우선될 수 있음 → 테스트 시 README §테스트의 unset ALLOWED_ORIGINS 권장.
# 데모: VS Code Live Server는 5500 예시. 파일을 file:// 로 열려면 "null" 를 배열에 포함(예: ..., "null"]).
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5500","http://127.0.0.1:5500"]
# 내부 검증 전용(비프로덕션): JWT 대신 허용할 공유 Bearer 토큰(APP_ENV=development 일 때만 동작). DB에 INTERNAL_BYPASS_USERNAME 사용자가 있어야 함.
INTERNAL_BYPASS_ENABLED=false
INTERNAL_BYPASS_BEARER_TOKEN=
INTERNAL_BYPASS_USERNAME=admin

# ─── Database ─────────────────────────────────────────────────────────────────
# 로컬(dev): localhost / 운영(prod): Docker 서비스명 (예: idr-postgres)
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql+asyncpg://idr:${POSTGRES_PASSWORD}@localhost:15432/idr_analytics

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# 교육용 /ide/docs/rules/ — 비우면 리포의 demo/ide 를 자동 사용. 터널·비표준 배치면 절대 경로 지정.
# IDE_STATIC_ROOT=

# ─── Analysis Routing ─────────────────────────────────────────────────────────
AI_ESCALATION_THRESHOLD=70
PANDAS_MAX_ROWS=2000000

# ─── LLM (Claude API) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=4096

# ─── Ollama (온프레미스 옵션) ─────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─── Dify (Self-hosted) ───────────────────────────────────────────────────────
# 공인 lis·Tier2(agent) 502·401·curl 검증·8000/8010 재기동: docs/rules/lis_dify_public_troubleshooting.md
# DIFY_API_BASE_URL — 브라우저가 아니라 **uvicorn(FastAPI)이 실행되는 PC**에서 Dify API에 닿는 베이스 URL + `/v1`.
#   강의 PC에서 Dify가 같은 머신·루프백이면 보통 `http://127.0.0.1:8080/v1` (해당 PC에서 curl로 확인).
DIFY_API_BASE_URL=http://127.0.0.1:8080/v1
# Dify 앱 API 키 (Studio → API 접근).
DIFY_API_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DIFY_WORKFLOW_ID — **UUID만** (workflows/run 응답의 workflow_id 등). 앱 표시 이름·문자열을 넣으면 잘못된 경로로 가 Tier2가 깨짐.
#   단일 워크플로에 묶인 API 키만 쓰면 비워도 됨(요청 본문에서 workflow_id 생략).
DIFY_WORKFLOW_ID=
# Tier2 워크플로 내부 HTTP Request 노드 → FastAPI 호출이 401이면: 노드의 Authorization Bearer(JWT)가 비었거나 만료.
#   `make dify-fastapi-jwt-bearer` 또는 `infra/dify/scripts/fetch_fastapi_jwt.py --bearer` 로 발급해 스튜디오 헤더에 반영 → uvicorn 재시작 후 재시도.

# ─── SCM / CRM ───────────────────────────────────────────────────────────────
PROPHET_CHANGEPOINT_SCALE=0.05
FORECAST_DEFAULT_DAYS=30
KMEANS_DEFAULT_CLUSTERS=4
CHURN_RECENCY_THRESHOLD_DAYS=90
