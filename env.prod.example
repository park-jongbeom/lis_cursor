# 로컬 «운영형» 스택용 .env.prod 템플릿 — Git 에 올리지 말고 프로젝트 루트에 `.env.prod` 로 복사해 사용한다.
# (`docker-compose.test.yml` 격리 스택·`make test` 용이 아님.)
APP_ENV=production
SECRET_KEY=change-me-use-secrets-token-hex-32

# 데모 출처: 로컬(9080·Live Server)·공개 URL(`make open-lis` 기본값과 동일) 등
# bash에서 `set -a && source .env.prod` 할 때는 JSON 전체를 작은따옴표로 감싸야 한다(큰따옴표만 쓰면 셸이 값을 자름).
ALLOWED_ORIGINS='["https://lis.qk54r71z.freeddns.org","http://127.0.0.1:9080","http://localhost:9080","http://127.0.0.1:5500","http://localhost:5500"]'

POSTGRES_PASSWORD=change-me-use-strong-password-in-production
# 호스트에서 uvicorn·Alembic 실행 시: compose 가 루프백에 노출한 포트
DATABASE_URL=postgresql+asyncpg://idr:${POSTGRES_PASSWORD}@127.0.0.1:15432/idr_analytics
REDIS_URL=redis://127.0.0.1:6379/0
# FastAPI 를 같은 compose 네트워크의 컨테이너로만 올릴 때:
# DATABASE_URL=postgresql+asyncpg://idr:${POSTGRES_PASSWORD}@idr-postgres:5432/idr_analytics
# REDIS_URL=redis://idr-redis:6379/0

DATA_UPLOAD_DIR=./data/uploads

# /ide/docs/rules/ — 비우면 앱이 리포의 demo/ide 를 자동 탐색. 안 맞으면 리포 루트 기준 절대 경로로 지정 후 uvicorn 재시작.
# IDE_STATIC_ROOT=/path/to/lis_cursor/demo/ide

AI_ESCALATION_THRESHOLD=70
PANDAS_MAX_ROWS=2000000

ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=4096

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Dify는 브라우저가 아니라 **uvicorn이 도는 호스트**에서 호출됨 — 그 호스트에서 열리는 API 베이스 + `/v1`.
# 예: 로컬 compose `http://127.0.0.1:8080/v1` · 원격 Dify만 있으면 Tailscale IP 등
DIFY_API_BASE_URL=http://127.0.0.1:8080/v1
DIFY_API_KEY=
# DIFY_WORKFLOW_ID 는 **UUID만** 넣는다(앱 표시 이름·임의 문자열 금지). 단일 워크플로 API 키면 비워도 됨.
DIFY_WORKFLOW_ID=

PROPHET_CHANGEPOINT_SCALE=0.05
FORECAST_DEFAULT_DAYS=30
KMEANS_DEFAULT_CLUSTERS=4
CHURN_RECENCY_THRESHOLD_DAYS=90
