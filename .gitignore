# 내부 참조 문서 — 외부 공개 금지
ref_files/

# ─── Secrets & 환경 변수 ───────────────────────────────────────────────────────
# 이름이 .env 로 시작하는 파일은 전부 무시 (예: .env, .env.example, .env.local, vendor/.env.example)
.env*
# 템플릿은 Git 에 `env.example`, `env.prod.example`, `infra/dify/env.vendor.example` 등 점 없는 이름으로 둔다.
# 점 없는 로컬 env
env.local
env.*.local
.envrc
.direnv/

# Docker compose override (로컬 전용 — 패스워드·경로 포함 가능)
docker-compose.override.yml
docker-compose.local.yml
docker-compose.*.local.yml

# 비밀·키·인증서 (예시·gitkeep 만 예외)
*.pem
!**/.gitkeep
id_rsa
id_ecdsa
id_ed25519
*.key
!*.key.example
*.p12
*.pfx
*.jks

# 클라우드·CI 서비스 계정 JSON (예시 파일명은 수동으로 add 가능)
*credentials*.json
google-services.json
.terraform.tfstate
.terraform.tfstate.*
*.tfvars
!*.tfvars.example

# Dify 1.13+ (런타임 데이터; 템플릿은 infra/dify/env.vendor.example)
infra/dify/vendor/volumes/
# nginx/ssl 에 실인증서가 생기면 추적 방지 (.gitkeep 만 유지)
infra/dify/vendor/nginx/ssl/*
!infra/dify/vendor/nginx/ssl/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
*.egg
*.egg-info/
dist/
build/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.tox/
.nox/
.hypothesis/
.dmypy.json
dmypy.json
celerybeat-schedule
celerybeat.pid

# 로컬 데이터·덤프
*.sqlite
*.sqlite3
*.db-journal

# Jupyter
.ipynb_checkpoints/

# 로그·PID·백업
*.log
*.pid
*.bak
*.orig
*~
\#*\#

# IDE / 에디터 (저장소에 올리는 설정만 예외)
.idea/
*.swp
*.swo
.vscode/launch.json
.vscode/tasks.json
.vscode/*.local.json

# OS
.DS_Store
Thumbs.db
Desktop.ini
.AppleDouble

# 캐시·도구
.cache/
.parcel-cache/
.docker/
.terraform/
