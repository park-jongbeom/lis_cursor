# ga-server Docker 스택용 — 리포 루트에 `.env.idr` 로 복사 후 비밀번호·키 설정 (Git 제외)
APP_ENV=production
SECRET_KEY=openssl-rand-hex-32-here
ALLOWED_ORIGINS=["https://lis.qk54r71z.freeddns.org"]

INTERNAL_BYPASS_ENABLED=false
INTERNAL_BYPASS_BEARER_TOKEN=
INTERNAL_BYPASS_USERNAME=admin

POSTGRES_PASSWORD=change-me-strong
DATABASE_URL=postgresql+asyncpg://idr:${POSTGRES_PASSWORD}@idr-postgres:5432/idr_analytics
REDIS_URL=redis://idr-redis:6379/0
DATA_UPLOAD_DIR=/app/data/uploads

AI_ESCALATION_THRESHOLD=70
PANDAS_MAX_ROWS=2000000

ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=4096

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Tier2: Dify 가 Tailscale 등 다른 호스트에 있으면 그 베이스 URL
DIFY_API_BASE_URL=http://100.82.189.32:8080/v1
DIFY_API_KEY=
DIFY_WORKFLOW_ID=

PROPHET_CHANGEPOINT_SCALE=0.05
FORECAST_DEFAULT_DAYS=30
KMEANS_DEFAULT_CLUSTERS=4
CHURN_RECENCY_THRESHOLD_DAYS=90
