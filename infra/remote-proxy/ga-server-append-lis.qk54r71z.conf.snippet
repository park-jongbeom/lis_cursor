# ga-server Docker nginx 전용 — 공인 `lis.*` URL 엣지 (TLS·경로 분배)
#
# FastAPI·Dify 는 사용자 로컬(또는 Tailscale IP)에서 기동한다. 이 파일은 원격에 앱을 올리지 않고
# 브라우저가 `https://lis.../` 로 들어올 때만 쓰는 역프록시 예시다.
#
# 목표:
#   https://lis.qk54r71z.freeddns.org/     → IDR 데모 정적 (demo/index.html)
#   https://lis.../api/v1/...             → IDR FastAPI
#   https://lis.../health, /docs, …      → FastAPI
#   그 외 (/apps, /console 등)            → Dify (기존과 같이 루트 패스로 프록시)
#
# 배포: 실제 편집 파일 저장 후
#   docker exec ga-nginx nginx -t && docker exec ga-nginx nginx -s reload
#
# 반드시 채욄 것:
#   - DEV_IP: IDR FastAPI·Dify 가 떠 있는 호스트(ga-server 가 TCP 로 접근 가능)
#   - LIS_DEMO_ROOT: 서버(또는 마운트 볼륨) 위 IDR 리포의 demo 디렉터리 절대 경로
#     예: /home/ubuntu/lis_cursor/demo  (rsync/git 으로 동기화된 경로)
#
# 선행: DNS A 레코드, certbot 등 TLS (기존 lis 인증서 경로와 맞출 것)

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80;
    server_name lis.qk54r71z.freeddns.org;

    location /.well-known/acme-challenge/ {
        root /var/www/static;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    server_name lis.qk54r71z.freeddns.org;

    ssl_certificate     /etc/letsencrypt/live/lis.qk54r71z.freeddns.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/lis.qk54r71z.freeddns.org/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 80m;

    # ── IDR FastAPI ──
    location /api/v1/ {
        proxy_connect_timeout 10s;
        proxy_pass http://DEV_IP:8000/api/v1/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }

    location = /health {
        proxy_pass http://DEV_IP:8000/health;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /docs {
        proxy_pass http://DEV_IP:8000/docs;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /openapi.json {
        proxy_pass http://DEV_IP:8000/openapi.json;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ── 루트만 IDR 데모 HTML (브라우저 기본 진입) ──
    location = / {
        root LIS_DEMO_ROOT;
        try_files /index.html =404;
    }

    # ── Dify (Studio·앱 등 — /apps, /console …) ──
    location / {
        proxy_connect_timeout 10s;
        proxy_pass http://DEV_IP:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 3600s;
        proxy_buffering off;
    }
}
