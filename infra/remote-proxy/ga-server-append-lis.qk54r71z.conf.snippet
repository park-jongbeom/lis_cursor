# ga-server Docker nginx 에 붙일 스니펫
# 실제 편집 파일(호스트): /home/ubuntu/ga-api-platform/docs/nginx/go-almond.swagger.conf
# 컨테이너: ga-nginx → 위 파일이 /etc/nginx/conf.d/default.conf 로 마운트됨
#
# 배포: 파일 저장 후
#   ssh ga-server 'docker exec ga-nginx nginx -t && docker exec ga-nginx nginx -s reload'
#
# 선행 작업:
#   1) DNS A 레코드: lis.qk54r71z.freeddns.org → ga-server 공인 IP
#   2) 인증서: ga-server 에서 certbot 로 lis 전용 발급 (아래 server 블록의 ssl 경로와 일치시킬 것)
#      예: sudo certbot certonly --webroot -w /home/ubuntu/ga-api-platform/docs/nginx/static \
#          -d lis.qk54r71z.freeddns.org
#   3) DEV_IP: SSH로 붙어 있는 IDR/Dify 호스트에 ga-server 가 TCP 로 닿는 주소
#      (기존 labeling-vscode-claude 블록은 Tailscale 100.82.189.32:8000 프록시 패턴)

# ── WebSocket/SSE (Dify) 용 — go-almond.swagger.conf 전체에 아래 map 이 없으면
#    이 스니펫의 server 블록보다 위(파일 상단, 첫 server { } 앞)에 한 번만 붙인다.
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

# ── HTTP: ACME + HTTPS 리다이렉트 ────────────────────────────────────────────
server {
    listen 80;
    server_name lis.qk54r71z.freeddns.org;

    location /.well-known/acme-challenge/ {
        root /var/www/static;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ── HTTPS: FastAPI + Dify (같은 도메인) ─────────────────────────────────────
server {
    listen 443 ssl;
    server_name lis.qk54r71z.freeddns.org;

    ssl_certificate     /etc/letsencrypt/live/lis.qk54r71z.freeddns.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/lis.qk54r71z.freeddns.org/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 15m;

    # IDR FastAPI
    location /api/v1/ {
        proxy_connect_timeout 10s;
        proxy_pass http://DEV_IP:8000/api/v1/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }

    # 루트는 Dify 직결 방지 → /dify/ 로 유도
    location = / {
        return 302 https://$host/dify/;
    }
    location = /dify {
        return 302 https://$host/dify/;
    }
    # 진입 경로: /dify/* → 백엔드에서는 /* 로 스트립
    location /dify/ {
        proxy_connect_timeout 10s;
        rewrite ^/dify/(.*)$ /$1 break;
        proxy_pass http://DEV_IP:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 3600s;
        proxy_buffering off;
    }
    # SPA·정적 리소스 (/apps, /_next 등) — Dify 0.15 는 루트 경로를 쓰므로 동일 server 에서 프록시 유지
    location / {
        proxy_connect_timeout 10s;
        proxy_pass http://DEV_IP:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 3600s;
        proxy_buffering off;
    }
}
